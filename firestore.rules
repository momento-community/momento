rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────────────────
    // Helpers
    // ────────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function roleOf() {
      return userDoc().data.get('role', 'user');
    }

    function isAdmin() {
      return isSignedIn() && roleOf() == 'admin';
    }

    function isOrganisor() {
      return isSignedIn() && roleOf() in ['organisor', 'admin'];
    }

    // Banned users keep read access (so they can still see why) but lose
    // every write. Default false for legacy docs without the field.
    function isBanned() {
      return isSignedIn() && userDoc().data.get('is_banned', false) == true;
    }

    function hasFreemiumQuota() {
      return userDoc().data.is_premium == true
          || userDoc().data.freemium_used < 5;
    }

    // ────────────────────────────────────────────────────────────────────
    // users/{uid}
    // ────────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid)
        && request.resource.data.email is string
        && request.resource.data.freemium_used == 0
        && request.resource.data.is_premium == false
        && request.resource.data.role == 'user'
        && request.resource.data.get('is_banned', false) == false
        && request.resource.data.created_at == request.time;

      // Self-update: banned users can't touch their own doc.
      allow update: if isOwner(uid)
        && !isBanned()
        && request.resource.data.is_premium == resource.data.is_premium
        && request.resource.data.freemium_used >= resource.data.freemium_used
        && request.resource.data.freemium_used <= resource.data.freemium_used + 1
        && request.resource.data.get('is_banned', false) == resource.data.get('is_banned', false)
        && (
          request.resource.data.get('role', 'user') == resource.data.get('role', 'user')
          || (
            resource.data.get('role', 'user') == 'user'
            && request.resource.data.role == 'organisor'
          )
        );

      // Admin can update any user doc, including role transitions and the
      // ban flag.
      allow update: if isAdmin();

      allow create: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────────────
    // momentos/{id}
    // ────────────────────────────────────────────────────────────────────
    match /momentos/{id} {
      allow read: if true;

      allow create: if (isOrganisor() || isAdmin())
        && !isBanned()
        && (
          isOwner(request.resource.data.organizer_id) || isAdmin()
        )
        && hasFreemiumQuota()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.category is string
        && request.resource.data.start_datetime is timestamp
        && request.resource.data.end_datetime is timestamp
        && request.resource.data.start_datetime < request.resource.data.end_datetime
        && request.resource.data.duration_days is int
        && request.resource.data.duration_days >= 1
        && request.resource.data.duration_days <= 5
        && request.resource.data.location_geopoint is latlng
        && request.resource.data.location_geohash is string
        && request.resource.data.like_count == 0
        && request.resource.data.view_count == 0
        && request.resource.data.is_active == true
        && request.resource.data.created_at == request.time;

      allow update: if isOwner(resource.data.organizer_id)
        && !isBanned()
        && request.resource.data.organizer_id == resource.data.organizer_id
        && request.resource.data.created_at == resource.data.created_at;

      allow update: if isAdmin();

      allow delete: if (isOwner(resource.data.organizer_id) && !isBanned())
        || isAdmin();
    }

    // ────────────────────────────────────────────────────────────────────
    // follows/{id}
    // ────────────────────────────────────────────────────────────────────
    match /follows/{id} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.follower_id)
        && !isBanned()
        && request.resource.data.following_id is string
        && request.resource.data.created_at == request.time;
      allow delete: if isOwner(resource.data.follower_id) || isAdmin();
    }

    // ────────────────────────────────────────────────────────────────────
    // transactions/{id} — v2 (Stripe).
    // ────────────────────────────────────────────────────────────────────
    match /transactions/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.user_id) || isAdmin());
      allow write: if false;
    }

    // ────────────────────────────────────────────────────────────────────
    // audit_log/{id} — admin-only, append-only.
    //
    // Each entry captures one admin-initiated mutation. We keep the schema
    // permissive (before/after as maps) so it can grow without rule churn;
    // a tighter shape can land in R4.x once we stabilise the action set.
    // ────────────────────────────────────────────────────────────────────
    match /audit_log/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.actor_id == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.target_id is string
        && request.resource.data.target_type is string
        && request.resource.data.created_at == request.time;
      // Append-only by construction — never edit or delete history.
      allow update, delete: if false;
    }
  }
}
