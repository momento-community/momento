rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────────────────
    // Helpers
    // ────────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Returns true when the user has remaining freemium quota or is premium.
    function hasFreemiumQuota() {
      return userDoc().data.is_premium == true
          || userDoc().data.freemium_used < 5;
    }

    // ────────────────────────────────────────────────────────────────────
    // users/{uid}
    // ────────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();

      // Initial user-doc creation by the user themselves.
      allow create: if isOwner(uid)
        && request.resource.data.email is string
        && request.resource.data.freemium_used == 0
        && request.resource.data.is_premium == false
        && request.resource.data.created_at == request.time;

      // Profile self-edits — cannot self-grant premium or reset freemium.
      allow update: if isOwner(uid)
        && request.resource.data.is_premium == resource.data.is_premium
        && request.resource.data.freemium_used >= resource.data.freemium_used
        // freemium_used can only grow by 1 per write (matches createMomento txn)
        && request.resource.data.freemium_used <= resource.data.freemium_used + 1;
    }

    // ────────────────────────────────────────────────────────────────────
    // momentos/{id}
    // ────────────────────────────────────────────────────────────────────
    match /momentos/{id} {
      allow read: if true;  // public discovery feed

      // Create: must be the organizer, must have quota, must include all
      // required fields, end must be after start, max 5-day duration.
      allow create: if isOwner(request.resource.data.organizer_id)
        && hasFreemiumQuota()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.category is string
        && request.resource.data.start_datetime is timestamp
        && request.resource.data.end_datetime is timestamp
        && request.resource.data.start_datetime < request.resource.data.end_datetime
        && request.resource.data.duration_days is int
        && request.resource.data.duration_days >= 1
        && request.resource.data.duration_days <= 5
        && request.resource.data.location_geopoint is latlng
        && request.resource.data.location_geohash is string
        && request.resource.data.organizer_id == request.auth.uid
        && request.resource.data.like_count == 0
        && request.resource.data.view_count == 0
        && request.resource.data.is_active == true
        && request.resource.data.created_at == request.time;

      // Update: only the organizer, and they cannot change ownership /
      // counters / created_at. liked_by toggles are handled by `like` action.
      allow update: if isOwner(resource.data.organizer_id)
        && request.resource.data.organizer_id == resource.data.organizer_id
        && request.resource.data.created_at == resource.data.created_at;

      // Delete: only the organizer.
      allow delete: if isOwner(resource.data.organizer_id);
    }

    // ────────────────────────────────────────────────────────────────────
    // follows/{id}
    // ────────────────────────────────────────────────────────────────────
    match /follows/{id} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.follower_id)
        && request.resource.data.following_id is string
        && request.resource.data.created_at == request.time;
      allow delete: if isOwner(resource.data.follower_id);
    }

    // ────────────────────────────────────────────────────────────────────
    // transactions/{id} — v2 (Stripe). Created by Functions in v2; until then
    // no client writes.
    // ────────────────────────────────────────────────────────────────────
    match /transactions/{id} {
      allow read: if isSignedIn() && isOwner(resource.data.user_id);
      allow write: if false;
    }
  }
}
