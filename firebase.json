{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "momento-b23c0",
          "appId": "1:357454320356:android:073e2256b5114537b812f1",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "momento-b23c0",
          "configurations": {
            "android": "1:357454320356:android:073e2256b5114537b812f1",
            "ios": "1:357454320356:ios:3d5d35618ab23ae7b812f1",
            "web": "1:357454320356:web:3f8c6df705a50aa2b812f1"
          }
        }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "momento-b23c0",
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|woff2|png|jpg|jpeg|svg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  }
}
