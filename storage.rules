rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Explicit allowlist — `image/.*` accepts `image/svg+xml`, which can
    // carry script tags and execute as a stored-XSS vector when loaded
    // directly (e.g. from a clicked Storage URL). The Flutter clients
    // only ever upload jpeg / png / webp via `image_picker`, so anything
    // outside that set is either an attack or a bug worth surfacing.
    function isImage() {
      return request.resource.contentType == 'image/jpeg'
          || request.resource.contentType == 'image/png'
          || request.resource.contentType == 'image/webp';
    }

    function under10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // Cross-service: admins can write any user/momento image. Reads the
    // user's own role from Firestore. Defaults to 'user' when the field
    // is missing on legacy docs.
    function isAdmin() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
            .data.get('role', 'user') == 'admin';
    }

    // Avatars: exactly `users/{uid}/avatar.jpg` — not `{allPaths=**}`,
    // which would let a user write arbitrarily-nested paths under their
    // own scope (cache pollution / billing surprise surface).
    // `StorageRepository.uploadAvatar` always writes this exact path.
    match /users/{uid}/avatar.jpg {
      allow read: if true;
      allow write: if (isOwner(uid) || isAdmin())
        && isImage()
        && under10MB();
    }

    // Momento photos: exactly four segments
    // `momentos/{organizerUid}/{momentoId}/{filename}`. The repo writes a
    // fresh-uuid filename per upload, so the leaf segment is variable but
    // the depth is fixed. Tighter than the old `{allPaths=**}` for the
    // same reason as avatars above.
    match /momentos/{organizerUid}/{momentoId}/{filename} {
      allow read: if true;
      allow write: if (isOwner(organizerUid) || isAdmin())
        && isImage()
        && under10MB();
    }
  }
}
